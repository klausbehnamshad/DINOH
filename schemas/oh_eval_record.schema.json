{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://c2dh.uni.lu/schemas/oh_eval_record.schema.json",
  "title": "C²DH Oral History Evaluation Record",
  "description": "Research/benchmark contract for a goldstandard evaluation record. Supersets the LuxOH-CMDI minimal metadata schema (which remains the institutional minimum) and additionally enforces the evaluation-specific structures: the synthetic flag, the transcript, the interpretive layer, and per-segment analytical annotations. Top level is deliberately tolerant of extra fields; the evaluation-specific nested structures are validated strictly.",
  "type": "object",
  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}_[A-Z]{2,10}_[0-9]{4}$",
      "description": "Stable ID (YYYY-MM-DD_LHI_####)"
    },
    "interview_date": { "type": "string", "format": "date" },
    "interviewer": { "type": "string" },
    "consent_status": {
      "type": "string",
      "enum": ["research-only", "teaching", "public", "embargoed"]
    },
    "accessRights": {
      "type": "string",
      "enum": ["open", "restricted", "closed"]
    },
    "title": { "type": "string" },
    "interviewee_display": { "type": "string" },
    "language": { "type": "string", "description": "ISO 639-3 language code" },
    "spatial": { "type": "string" },
    "keywords": { "type": "array", "items": { "type": "string" } },
    "abstract": { "type": "string", "maxLength": 500 },

    "synthetic": {
      "const": true,
      "description": "Every evaluation record must be explicitly flagged synthetic."
    },
    "transcript": {
      "type": "string",
      "minLength": 1,
      "description": "Full interview transcript text the tasks operate on."
    },
    "interpretive_layer": {
      "type": "object",
      "description": "L2 interpretive layer (human goldstandard).",
      "properties": {
        "narrative_arc": { "type": "string", "minLength": 1 },
        "central_tension": { "type": "string", "minLength": 1 },
        "positioning_summary": { "type": "string", "minLength": 1 },
        "gold_rationale": { "type": "string", "minLength": 1 },
        "annotator_id": { "type": "string", "minLength": 1 }
      },
      "required": [
        "narrative_arc",
        "central_tension",
        "positioning_summary",
        "gold_rationale",
        "annotator_id"
      ],
      "additionalProperties": false
    },
    "timecoded_segments": {
      "type": "array",
      "minItems": 1,
      "description": "L1 segments; each carries analytical annotations (L2).",
      "items": {
        "type": "object",
        "properties": {
          "start": {
            "type": "string",
            "pattern": "^[0-9]{2}:[0-5][0-9]:[0-5][0-9]$",
            "description": "HH:MM:SS"
          },
          "end": {
            "type": "string",
            "pattern": "^[0-9]{2}:[0-5][0-9]:[0-5][0-9]$",
            "description": "HH:MM:SS"
          },
          "label": { "type": "string", "minLength": 1 },
          "analytical_annotations": {
            "type": "object",
            "description": "Per-segment analytical coding (human goldstandard).",
            "properties": {
              "selected_topic": { "type": "string", "minLength": 1 },
              "selected_frame": { "type": "string", "minLength": 1 },
              "selected_rhetorical_pattern": { "type": "string", "minLength": 1 },
              "selected_discursive_position": { "type": "string", "minLength": 1 },
              "gold_rationale": { "type": "string", "minLength": 1 },
              "annotator_id": { "type": "string", "minLength": 1 },
              "alternative_codings": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "required": [
              "selected_topic",
              "selected_frame",
              "selected_rhetorical_pattern",
              "selected_discursive_position",
              "gold_rationale",
              "annotator_id",
              "alternative_codings"
            ],
            "additionalProperties": false
          }
        },
        "required": ["start", "end", "label", "analytical_annotations"],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "record_id",
    "interview_date",
    "interviewer",
    "consent_status",
    "accessRights",
    "title",
    "language",
    "synthetic",
    "transcript",
    "interpretive_layer",
    "timecoded_segments"
  ]
}
