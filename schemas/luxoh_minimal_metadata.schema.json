{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Luxembourg Minimal Metadata Schema for Oral History",
  "type": "object",
  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}_[A-Z]{2,10}_[0-9]{4}$",
      "description": "Stable ID (YYYY-MM-DD_LHI_####)"
    },
    "interview_date": {
      "type": "string",
      "format": "date",
      "description": "ISO 8601 interview date"
    },
    "interviewer": {
      "type": "string",
      "description": "Name of interviewer (optional ORCID)"
    },
    "consent_status": {
      "type": "string",
      "enum": ["research-only", "teaching", "public", "embargoed"],
      "description": "Rights based on participant consent"
    },
    "accessRights": {
      "type": "string",
      "enum": ["open", "restricted", "closed"],
      "description": "Repository access category"
    },
    "title": {
      "type": "string",
      "description": "Interview title or label"
    },
    "interviewee_display": {
      "type": "string",
      "description": "Pseudonym or display name"
    },
    "language": {
      "type": "string",
      "description": "ISO 639-3 language code"
    },
    "spatial": {
      "type": "string",
      "description": "Place of interview (controlled vocabulary)"
    },
    "keywords": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Controlled vocabulary keywords"
    },
    "abstract": {
      "type": "string",
      "maxLength": 500,
      "description": "2–3 sentence summary"
    },
    "timecoded_segments": {
      "type": "array",
      "description": "Start–end list of segments",
      "items": {
        "type": "object",
        "properties": {
          "start": { "type": "string" },
          "end": { "type": "string" },
          "label": { "type": "string" }
        },
        "required": ["start", "end", "label"]
      }
    }
  },
  "required": [
    "record_id",
    "interview_date",
    "interviewer",
    "consent_status",
    "accessRights",
    "title",
    "language"
  ]
}
